+// CJS compatibility shim for Node.js v22+ (Expo SDK 51)
+// expo-sqlite has no JS config plugin (only native modules declared in expo-module.config.json).
+// When expo's config-plugin system require()s this package on Node.js v22+, it expects a
+// function. This no-op plugin satisfies that contract without altering the app config.
+// Metro bundler uses its own resolver and loads the real ESM build (index.js) for the app.
+function withExpoSQLite(config) {
+  return config;
+}
+module.exports = withExpoSQLite;
+module.exports.default = withExpoSQLite;

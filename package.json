    "@react-navigation/native-stack": "^6.9.26",
    "@rnmapbox/maps": "^10.1.19",
    "expo": "~51.0.0",
    "expo-build-properties": "~0.12.3",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.7",
    "expo-location": "~17.0.1",
    "expo-notifications": "^56.0.18",

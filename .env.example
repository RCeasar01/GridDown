# GridDown Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
#
# EXPO_PUBLIC_ variables are inlined at build time and accessible in the app.
# Variables without EXPO_PUBLIC_ are only available in metro/EAS build steps.

# ---------------------------------------------------------------------------
# RevenueCat
# Get these from https://app.revenuecat.com/apps
# ---------------------------------------------------------------------------
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Legal / Support URLs
# Default to GitHub Pages hosted docs if not overridden.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_PRIVACY_URL=https://rceasar01.github.io/GridDown/privacy
EXPO_PUBLIC_TERMS_URL=https://rceasar01.github.io/GridDown/terms
EXPO_PUBLIC_SUPPORT_URL=https://bannedproduct.com/support
EXPO_PUBLIC_DISCORD_URL=https://discord.gg/griddown

# ---------------------------------------------------------------------------
# App Store / Play Store URLs (used for share/rate flows)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/us/app/griddown/idXXXXXXXXXX
EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.bannedproduct.griddown

# ---------------------------------------------------------------------------
# EAS Project (used by eas.json, not inlined into the app)
# ---------------------------------------------------------------------------
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Sentry (optional — add sentry-expo if you enable crash reporting)
# ---------------------------------------------------------------------------
# EXPO_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# ---------------------------------------------------------------------------
# Supabase (required for Community Alerts feature)
# Get these from https://app.supabase.com/project/_/settings/api
# Leave blank to disable Community Alerts gracefully.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ---------------------------------------------------------------------------
# Feature Flags
# Set to 'true' to enable, 'false' to disable
# ---------------------------------------------------------------------------
EXPO_PUBLIC_AI_ADVISOR_ENABLED=true
EXPO_PUBLIC_USB_EXPORT_ENABLED=true
EXPO_PUBLIC_REFERRAL_ENABLED=false

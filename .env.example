# GridDown Environment Variables
# Copy this file to .env and fill in real values

# RevenueCat API Keys
REVENUECAT_IOS_API_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_ANDROID_API_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# RevenueCat Entitlement IDs
ENTITLEMENT_MONTHLY=griddown_monthly
ENTITLEMENT_YEARLY=griddown_yearly
ENTITLEMENT_LIFETIME_STANDARD=griddown_lifetime_standard
ENTITLEMENT_DISCORD=griddown_discord
ENTITLEMENT_EXTREME_MONTHLY=griddown_extreme_monthly
ENTITLEMENT_EXTREME_YEARLY=griddown_extreme_yearly
ENTITLEMENT_EXTREME_LIFETIME=griddown_extreme_lifetime

# EAS / Expo
EAS_PROJECT_ID=your-eas-project-id

# Discord Community
DISCORD_INVITE_URL=https://discord.gg/bannedproduct

# MapLibre / Offline Maps
MAPTILER_API_KEY=your-maptiler-api-key

# Referral System (future)
REFERRAL_BASE_URL=https://griddown.app/ref
REFERRAL_COMMISSION_RATE=0.20
